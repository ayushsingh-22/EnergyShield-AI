# EnergyShield AI - Environment Variables
# Copy this file to .env and fill in real values for local development.
# Never commit a real .env file.

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
MVP_COMMODITY_SCOPE=CRUDE_OIL

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# PostgreSQL (relational persistence: events, risk scores, scenarios,
# recommendations, audit trail - see backend/db)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=energyshield
POSTGRES_USER=energyshield
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://energyshield:change-me@localhost:5432/energyshield

# ---------------------------------------------------------------------------
# Neo4j (knowledge graph - see backend/graph)
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-too
NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------------
# Redis (event bus / job status / caching - see backend/orchestration)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# LLM provider (event extraction agent - see backend/agents)
# Use Claude/Anthropic models by default; deterministic fallback rules must
# still run when no key is configured.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5

# ---------------------------------------------------------------------------
# External data sources (Phase 1 ingestion - all optional for prototype;
# collectors fall back to seeded sample data when a key/URL is missing)
# ---------------------------------------------------------------------------
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
EIA_API_KEY=
FRED_API_KEY=
AISSTREAM_API_KEY=
PORTWATCH_API_URL=

# ---------------------------------------------------------------------------
# Scheduler / orchestration (Phase 10)
# ---------------------------------------------------------------------------
DATA_REFRESH_INTERVAL_MINUTES=15
SCENARIO_RISK_TRIGGER_THRESHOLD=70
