# EnergyShield AI - Environment Variables
# Copy this file to .env and fill in real values for local development.
# Never commit a real .env file.

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
MVP_COMMODITY_SCOPE=CRUDE_OIL

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# PostgreSQL (relational persistence: events, risk scores, scenarios,
# recommendations, audit trail - see backend/db)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=energyshield
POSTGRES_USER=energyshield
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://energyshield:change-me@localhost:5432/energyshield

# ---------------------------------------------------------------------------
# Neo4j (knowledge graph - see backend/graph)
# ---------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-too
NEO4J_DATABASE=neo4j

# ---------------------------------------------------------------------------
# Redis (event bus / job status / caching - see backend/orchestration)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# LLM provider (event extraction agent - see backend/agents)
# Use Claude/Anthropic models by default; deterministic fallback rules must
# still run when no key is configured.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-5

# ---------------------------------------------------------------------------
# External data sources (Phase 1 ingestion)
#
# Live feeds are OPT-IN: set ENABLE_LIVE_FEEDS=true to have collectors call
# the real sources below. When false (default), or when any individual fetch
# fails / its key is blank, that collector falls back to seeded sample data -
# so the app always runs, with or without network/keys.
# ---------------------------------------------------------------------------
ENABLE_LIVE_FEEDS=false

# News (GDELT DOC 2.1 API - free, no key required)
GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
# Optional: override the default energy/supply-chain news query
# GDELT_QUERY=

# Sanctions (OFAC SDN CSV - free, no key required)
OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.csv

# Chokepoint activity (IMF PortWatch ArcGIS FeatureServer - free, no key)
PORTWATCH_API_URL=https://services9.arcgis.com/weJ1QsnbMYJlCHdG/arcgis/rest/services/PortWatch_chokepoints_database/FeatureServer/0/query

# Commodity prices (EIA v2 primary, Alpha Vantage secondary - free keys)
EIA_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Vessel positions - AISStream.io (primary; free, instant API key at
# https://aisstream.io). WebSocket stream, polled briefly each cycle.
AISSTREAM_URL=wss://stream.aisstream.io/v0/stream
AISSTREAM_API_KEY=
# AISSTREAM_COLLECT_SECONDS=6
# Vessel positions - AISHub (secondary; free for data-sharing members,
# username-based, hard-limited to 1 request/minute)
AISHUB_URL=https://data.aishub.net/ws.php
AISHUB_USERNAME=

# ---------------------------------------------------------------------------
# Scheduler / orchestration (Phase 10)
# ---------------------------------------------------------------------------
DATA_REFRESH_INTERVAL_MINUTES=15
SCENARIO_RISK_TRIGGER_THRESHOLD=70
