# Copy to .env.local for local development.

# Base URL of the EnergyShield backend API.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Default is false: the frontend calls the live backend so every screen
# shows real, per-input computed results. Set to true only for frontend
# development without a running backend (serves static fixtures from
# src/api/mockData.js that do NOT vary with input).
VITE_USE_MOCK_DATA=false
